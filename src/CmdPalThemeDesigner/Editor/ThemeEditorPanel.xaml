<!-- Theme Editor Panel: Sidebar with presets, color pickers, font pickers, backdrop controls -->
<UserControl
    x:Class="CmdPalThemeDesigner.Editor.ThemeEditorPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="4">

            <!-- Presets Section -->
            <Expander IsExpanded="True" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="Preset Themes" FontWeight="SemiBold" />
                </Expander.Header>
                <Expander.Content>
                    <StackPanel x:Name="PresetListPanel" Spacing="4" Margin="0,4,0,0" />
                </Expander.Content>
            </Expander>

            <!-- Colors Section -->
            <Expander IsExpanded="False" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="Colors" FontWeight="SemiBold" />
                </Expander.Header>
                <Expander.Content>
                    <StackPanel x:Name="ColorEditorsPanel" Spacing="2" Margin="0,4,0,0" />
                </Expander.Content>
            </Expander>

            <!-- Fonts Section -->
            <Expander IsExpanded="False" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="Fonts" FontWeight="SemiBold" />
                </Expander.Header>
                <Expander.Content>
                    <StackPanel Spacing="16" Margin="0,8,0,0">
                        <!-- Primary Font -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Primary Font" FontSize="12" FontWeight="SemiBold"
                                       Opacity="0.8" />
                            <ComboBox x:Name="PrimaryFontCombo" HorizontalAlignment="Stretch"
                                      SelectionChanged="FontCombo_SelectionChanged" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <NumberBox x:Name="PrimaryFontSize" Header="Size" Value="14"
                                           Minimum="8" Maximum="36" SpinButtonPlacementMode="Compact"
                                           ValueChanged="FontSize_ValueChanged" />
                                <ComboBox x:Name="PrimaryFontWeight" Header="Weight"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="FontWeight_SelectionChanged" />
                            </Grid>
                        </StackPanel>

                        <!-- Title Font -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Title Font" FontSize="12" FontWeight="SemiBold"
                                       Opacity="0.8" />
                            <ComboBox x:Name="TitleFontCombo" HorizontalAlignment="Stretch"
                                      SelectionChanged="FontCombo_SelectionChanged" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <NumberBox x:Name="TitleFontSize" Header="Size" Value="16"
                                           Minimum="8" Maximum="48" SpinButtonPlacementMode="Compact"
                                           ValueChanged="FontSize_ValueChanged" />
                                <ComboBox x:Name="TitleFontWeight" Header="Weight"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="FontWeight_SelectionChanged" />
                            </Grid>
                        </StackPanel>

                        <!-- Caption Font -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Caption Font" FontSize="12" FontWeight="SemiBold"
                                       Opacity="0.8" />
                            <ComboBox x:Name="CaptionFontCombo" HorizontalAlignment="Stretch"
                                      SelectionChanged="FontCombo_SelectionChanged" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <NumberBox x:Name="CaptionFontSize" Header="Size" Value="12"
                                           Minimum="8" Maximum="24" SpinButtonPlacementMode="Compact"
                                           ValueChanged="FontSize_ValueChanged" />
                                <ComboBox x:Name="CaptionFontWeight" Header="Weight"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="FontWeight_SelectionChanged" />
                            </Grid>
                        </StackPanel>

                        <!-- Monospace Font -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Monospace Font" FontSize="12" FontWeight="SemiBold"
                                       Opacity="0.8" />
                            <ComboBox x:Name="MonoFontCombo" HorizontalAlignment="Stretch"
                                      SelectionChanged="FontCombo_SelectionChanged" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <NumberBox x:Name="MonoFontSize" Header="Size" Value="13"
                                           Minimum="8" Maximum="30" SpinButtonPlacementMode="Compact"
                                           ValueChanged="FontSize_ValueChanged" />
                                <ComboBox x:Name="MonoFontWeight" Header="Weight"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="FontWeight_SelectionChanged" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Expander.Content>
            </Expander>

            <!-- Backdrop Section -->
            <Expander IsExpanded="False" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="Backdrop" FontWeight="SemiBold" />
                </Expander.Header>
                <Expander.Content>
                    <StackPanel Spacing="12" Margin="0,8,0,0">
                        <ComboBox x:Name="BackdropStyleCombo" Header="Style"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="BackdropStyle_SelectionChanged">
                            <ComboBoxItem Content="Acrylic" Tag="Acrylic" />
                            <ComboBoxItem Content="Mica" Tag="Mica" />
                            <ComboBoxItem Content="None" Tag="None" />
                        </ComboBox>

                        <Slider x:Name="TintOpacitySlider" Header="Tint Opacity"
                                Minimum="0" Maximum="1" StepFrequency="0.05" Value="0.85"
                                ValueChanged="BackdropSlider_ValueChanged" />

                        <Slider x:Name="LuminositySlider" Header="Luminosity Opacity"
                                Minimum="0" Maximum="1" StepFrequency="0.05" Value="0.9"
                                ValueChanged="BackdropSlider_ValueChanged" />
                    </StackPanel>
                </Expander.Content>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
