<!-- CmdPal Preview: Visual replica of the Command Palette window -->
<UserControl
    x:Class="CmdPalThemeDesigner.Preview.CmdPalPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Simulated CmdPal window -->
    <Border Background="{ThemeResource LayerOnAcrylicPrimaryBackgroundBrush}"
            CornerRadius="8"
            BorderBrush="{ThemeResource CmdPal.CommandBarBorderBrush}"
            BorderThickness="1"
            MaxWidth="680" MinWidth="400"
            Padding="0">

        <Grid RowDefinitions="Auto,Auto,*,Auto">
            
            <!-- Search Bar -->
            <Grid Grid.Row="0" Padding="12,12,12,8">
                <Border Background="{ThemeResource CmdPal.SearchBoxBackground}"
                        BorderBrush="{ThemeResource CmdPal.SearchBoxBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Glyph="&#xE721;" FontSize="14"
                                  Foreground="{ThemeResource CmdPal.SearchBoxPlaceholderForeground}"
                                  VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="Search commands, files, settings..."
                                   Foreground="{ThemeResource CmdPal.SearchBoxPlaceholderForeground}"
                                   Tag="primary" FontFamily="{ThemeResource CmdPal.PrimaryFontFamily}"
                                   FontSize="{ThemeResource CmdPal.PrimaryFontSize}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="Ctrl+Space"
                                   Foreground="{ThemeResource CmdPal.SearchBoxPlaceholderForeground}"
                                   Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                   FontSize="{ThemeResource CmdPal.CaptionFontSize}"
                                   VerticalAlignment="Center" Opacity="0.6" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Top bar divider -->
            <Border Grid.Row="1" Height="1"
                    Background="{ThemeResource CmdPal.TopBarBorderBrush}" />

            <!-- Results list -->
            <ScrollViewer Grid.Row="2" MaxHeight="320" Padding="4,4,4,4">
                <StackPanel Spacing="2">
                    <!-- Selected item -->
                    <Border Background="{ThemeResource CmdPal.ListItemBackgroundSelected}"
                            CornerRadius="4" Padding="12,8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon Glyph="&#xE768;" FontSize="16"
                                      Foreground="{ThemeResource CmdPal.AccentColor}"
                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Open Settings"
                                           Foreground="{ThemeResource CmdPal.ListItemForeground}"
                                           Tag="primary" FontFamily="{ThemeResource CmdPal.PrimaryFontFamily}"
                                           FontSize="{ThemeResource CmdPal.PrimaryFontSize}" />
                                <TextBlock Text="PowerToys &gt; General"
                                           Foreground="{ThemeResource CmdPal.ListItemForegroundSecondary}"
                                           Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                           FontSize="{ThemeResource CmdPal.CaptionFontSize}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                        VerticalAlignment="Center">
                                <Border Background="{ThemeResource CmdPal.TagBackground}"
                                        BorderBrush="{ThemeResource CmdPal.TagBorderBrush}"
                                        BorderThickness="1" CornerRadius="3" Padding="6,2">
                                    <TextBlock Text="Settings"
                                               Foreground="{ThemeResource CmdPal.TagForeground}"
                                               Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                               FontSize="11" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Hover item -->
                    <Border Background="{ThemeResource CmdPal.ListItemBackgroundPointerOver}"
                            CornerRadius="4" Padding="12,8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon Glyph="&#xE8B7;" FontSize="16"
                                      Foreground="{ThemeResource CmdPal.ListItemForeground}"
                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Toggle Always On Top"
                                           Foreground="{ThemeResource CmdPal.ListItemForeground}"
                                           Tag="primary" FontFamily="{ThemeResource CmdPal.PrimaryFontFamily}"
                                           FontSize="{ThemeResource CmdPal.PrimaryFontSize}" />
                                <TextBlock Text="Window Management"
                                           Foreground="{ThemeResource CmdPal.ListItemForegroundSecondary}"
                                           Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                           FontSize="{ThemeResource CmdPal.CaptionFontSize}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                        VerticalAlignment="Center">
                                <Border Background="{ThemeResource CmdPal.TagBackground}"
                                        BorderBrush="{ThemeResource CmdPal.TagBorderBrush}"
                                        BorderThickness="1" CornerRadius="3" Padding="6,2">
                                    <TextBlock Text="Utility"
                                               Foreground="{ThemeResource CmdPal.TagForeground}"
                                               Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                               FontSize="11" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Normal items -->
                    <Border Background="{ThemeResource CmdPal.ListItemBackground}"
                            CornerRadius="4" Padding="12,8">
                        <Grid ColumnDefinitions="Auto,*">
                            <FontIcon Glyph="&#xE7AC;" FontSize="16"
                                      Foreground="{ThemeResource CmdPal.ListItemForeground}"
                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Launch Color Picker"
                                           Foreground="{ThemeResource CmdPal.ListItemForeground}"
                                           Tag="primary" FontFamily="{ThemeResource CmdPal.PrimaryFontFamily}"
                                           FontSize="{ThemeResource CmdPal.PrimaryFontSize}" />
                                <TextBlock Text="Utilities &gt; Color Picker"
                                           Foreground="{ThemeResource CmdPal.ListItemForegroundSecondary}"
                                           Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                           FontSize="{ThemeResource CmdPal.CaptionFontSize}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{ThemeResource CmdPal.ListItemBackground}"
                            CornerRadius="4" Padding="12,8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <FontIcon Glyph="&#xE8A5;" FontSize="16"
                                      Foreground="{ThemeResource CmdPal.ListItemForeground}"
                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Find and Replace in Files"
                                           Foreground="{ThemeResource CmdPal.ListItemForeground}"
                                           Tag="primary" FontFamily="{ThemeResource CmdPal.PrimaryFontFamily}"
                                           FontSize="{ThemeResource CmdPal.PrimaryFontSize}" />
                                <TextBlock Text="Search &gt; Advanced"
                                           Foreground="{ThemeResource CmdPal.ListItemForegroundSecondary}"
                                           Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                           FontSize="{ThemeResource CmdPal.CaptionFontSize}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                        VerticalAlignment="Center">
                                <Border Background="{ThemeResource CmdPal.TagBackground}"
                                        BorderBrush="{ThemeResource CmdPal.TagBorderBrush}"
                                        BorderThickness="1" CornerRadius="3" Padding="6,2">
                                    <TextBlock Text="Search"
                                               Foreground="{ThemeResource CmdPal.TagForeground}"
                                               Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                               FontSize="11" />
                                </Border>
                                <Border Background="{ThemeResource CmdPal.TagBackground}"
                                        BorderBrush="{ThemeResource CmdPal.TagBorderBrush}"
                                        BorderThickness="1" CornerRadius="3" Padding="6,2">
                                    <TextBlock Text="Files"
                                               Foreground="{ThemeResource CmdPal.TagForeground}"
                                               Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                               FontSize="11" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{ThemeResource CmdPal.ListItemBackground}"
                            CornerRadius="4" Padding="12,8">
                        <Grid ColumnDefinitions="Auto,*">
                            <FontIcon Glyph="&#xE74C;" FontSize="16"
                                      Foreground="{ThemeResource CmdPal.ListItemForeground}"
                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Crop and Lock Window"
                                           Foreground="{ThemeResource CmdPal.ListItemForeground}"
                                           Tag="primary" FontFamily="{ThemeResource CmdPal.PrimaryFontFamily}"
                                           FontSize="{ThemeResource CmdPal.PrimaryFontSize}" />
                                <TextBlock Text="Window Management"
                                           Foreground="{ThemeResource CmdPal.ListItemForegroundSecondary}"
                                           Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                           FontSize="{ThemeResource CmdPal.CaptionFontSize}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Command bar -->
            <Border Grid.Row="3"
                    BorderBrush="{ThemeResource CmdPal.DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="8,6">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="5 results"
                               Foreground="{ThemeResource CmdPal.ListItemForegroundSecondary}"
                               Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                               FontSize="{ThemeResource CmdPal.CaptionFontSize}"
                               VerticalAlignment="Center" Margin="8,0,0,0" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                        <Button Background="{ThemeResource CmdPal.ButtonBackground}"
                                Foreground="{ThemeResource CmdPal.ButtonForeground}"
                                BorderBrush="{ThemeResource CmdPal.ButtonBorderBrush}"
                                CornerRadius="4" Padding="8,4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                <TextBlock Text="Run"
                                           Tag="caption" FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                           FontSize="{ThemeResource CmdPal.CaptionFontSize}" />
                            </StackPanel>
                        </Button>
                        <Button Background="{ThemeResource CmdPal.ButtonBackground}"
                                Foreground="{ThemeResource CmdPal.ButtonForeground}"
                                BorderBrush="{ThemeResource CmdPal.ButtonBorderBrush}"
                                CornerRadius="4" Padding="8,4">
                            <FontIcon Glyph="&#xE712;" FontSize="12" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
