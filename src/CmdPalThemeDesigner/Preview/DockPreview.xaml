<!-- Dock Preview: Visual replica of the Dock bar -->
<UserControl
    x:Class="CmdPalThemeDesigner.Preview.DockPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{ThemeResource LayerOnAcrylicSecondaryBackgroundBrush}"
            CornerRadius="8"
            BorderBrush="{ThemeResource CmdPal.CommandBarBorderBrush}"
            BorderThickness="1"
            Padding="8,6"
            HorizontalAlignment="Center">

        <StackPanel Orientation="Horizontal" Spacing="4">
            <!-- Dock items -->
            <Border x:Name="DockItem1"
                    Background="{ThemeResource Dock.ItemBackground}"
                    BorderBrush="{ThemeResource Dock.ItemBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4" Padding="10,6"
                    PointerEntered="DockItem_PointerEntered"
                    PointerExited="DockItem_PointerExited">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE756;" FontSize="18"
                              Foreground="{ThemeResource Dock.ItemForeground}" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Terminal"
                                   Foreground="{ThemeResource Dock.ItemForeground}"
                                   FontFamily="{ThemeResource CmdPal.PrimaryFontFamily}"
                                   FontSize="13" />
                        <TextBlock Text="PowerShell"
                                   Foreground="{ThemeResource Dock.ItemForegroundSecondary}"
                                   FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                   FontSize="11" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="DockItem2"
                    Background="{ThemeResource Dock.ItemBackgroundPointerOver}"
                    BorderBrush="{ThemeResource Dock.ItemBorderBrushPointerOver}"
                    BorderThickness="1"
                    CornerRadius="4" Padding="10,6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE7C3;" FontSize="18"
                              Foreground="{ThemeResource Dock.ItemForeground}" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="VS Code"
                                   Foreground="{ThemeResource Dock.ItemForeground}"
                                   FontFamily="{ThemeResource CmdPal.PrimaryFontFamily}"
                                   FontSize="13" />
                        <TextBlock Text="Editing"
                                   Foreground="{ThemeResource Dock.ItemForegroundSecondary}"
                                   FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                   FontSize="11" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="DockItem3"
                    Background="{ThemeResource Dock.ItemBackground}"
                    BorderBrush="{ThemeResource Dock.ItemBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4" Padding="10,6"
                    PointerEntered="DockItem_PointerEntered"
                    PointerExited="DockItem_PointerExited">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE774;" FontSize="18"
                              Foreground="{ThemeResource Dock.ItemForeground}" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Browser"
                                   Foreground="{ThemeResource Dock.ItemForeground}"
                                   FontFamily="{ThemeResource CmdPal.PrimaryFontFamily}"
                                   FontSize="13" />
                        <TextBlock Text="3 tabs"
                                   Foreground="{ThemeResource Dock.ItemForegroundSecondary}"
                                   FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                   FontSize="11" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="DockItem4"
                    Background="{ThemeResource Dock.ItemBackgroundPressed}"
                    BorderBrush="{ThemeResource Dock.ItemBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4" Padding="10,6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE77B;" FontSize="18"
                              Foreground="{ThemeResource Dock.ItemForeground}" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Files"
                                   Foreground="{ThemeResource Dock.ItemForeground}"
                                   FontFamily="{ThemeResource CmdPal.PrimaryFontFamily}"
                                   FontSize="13" />
                        <TextBlock Text="Explorer"
                                   Foreground="{ThemeResource Dock.ItemForegroundSecondary}"
                                   FontFamily="{ThemeResource CmdPal.CaptionFontFamily}"
                                   FontSize="11" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Separator -->
            <Border Width="1" Height="28" Margin="4,0"
                    Background="{ThemeResource CmdPal.DividerStrokeColorDefaultBrush}" />

            <Border x:Name="DockItem5"
                    Background="{ThemeResource Dock.ItemBackground}"
                    BorderBrush="{ThemeResource Dock.ItemBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4" Padding="10,6"
                    PointerEntered="DockItem_PointerEntered"
                    PointerExited="DockItem_PointerExited">
                <FontIcon Glyph="&#xE710;" FontSize="18"
                          Foreground="{ThemeResource Dock.ItemForeground}" />
            </Border>
        </StackPanel>
    </Border>
</UserControl>
