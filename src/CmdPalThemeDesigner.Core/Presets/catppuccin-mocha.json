{
  "version": 2,
  "name": "Catppuccin Mocha",
  "author": "PowerToys",
  "description": "Warm, pastel dark theme based on the Catppuccin Mocha palette",
  "fonts": {
    "primary": {
      "family": "Inter",
      "size": 14,
      "weight": "Normal"
    },
    "monospace": {
      "family": "JetBrains Mono",
      "size": 13,
      "weight": "Normal"
    },
    "title": {
      "family": "Inter",
      "size": 17,
      "weight": "SemiBold"
    },
    "caption": {
      "family": "Inter",
      "size": 12,
      "weight": "Light"
    }
  },
  "palette": {
    "dark": {
      "foreground.primary": "#CDD6F4",
      "foreground.secondary": "#A6ADC8",
      "foreground.tertiary": "#A6ADC8",
      "foreground.disabled": "#55CDD6F4",
      "background.primary": "#801E1E2E",
      "background.secondary": "Transparent",
      "background.tertiary": "#313244",
      "accent": "#CBA6F7",
      "accent.text": "#FFFFFF",
      "border.default": "#45475A",
      "border.card": "#45475A"
    },
    "light": {
      "foreground.primary": "#4C4F69",
      "foreground.secondary": "#6C6F85",
      "foreground.tertiary": "#6C6F85",
      "foreground.disabled": "#554C4F69",
      "background.primary": "#A0EFF1F5",
      "background.secondary": "#66E6E9EF",
      "background.tertiary": "#E6E9EF",
      "accent": "#8839EF",
      "accent.text": "#FFFFFF",
      "border.default": "#BCC0CC",
      "border.card": "#DCE0E8"
    }
  },
  "backdrop": {
    "style": "Acrylic",
    "tintOpacity": 0.9,
    "luminosityOpacity": 0.85
  }
}
