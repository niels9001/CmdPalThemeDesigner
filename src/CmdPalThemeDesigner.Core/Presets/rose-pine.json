{
  "version": 2,
  "name": "Rosé Pine",
  "author": "PowerToys",
  "description": "All natural pine, faux fur, and a bit of soho vibes",
  "fonts": {
    "primary": {
      "family": "Georgia",
      "size": 14,
      "weight": "Normal"
    },
    "monospace": {
      "family": "Cascadia Code",
