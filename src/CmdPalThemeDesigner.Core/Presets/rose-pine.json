      "foreground.secondary": "#9893A5",
      "foreground.tertiary": "#9893A5",
      "foreground.disabled": "#55575279",
      "background.primary": "#A0FAF4ED",
      "background.secondary": "#66FFFAF3",
      "background.tertiary": "#FFFAF3",
      "accent": "#907AA9",
      "accent.text": "#FFFFFF",
      "border.default": "#CECACD",
