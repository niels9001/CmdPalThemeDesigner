{
  "version": 2,
  "name": "Colorful Light",
  "author": "PowerToys",
  "description": "The accent-tinted colorful theme in a bright, airy variant",
  "fonts": {
    "primary": {
      "family": "Segoe UI Variable",
      "size": 14,
      "weight": "Normal"
    },
    "monospace": {
      "family": "Cascadia Code",
      "size": 13,
      "weight": "Normal"
    },
    "title": {
      "family": "Segoe UI Variable",
      "size": 16,
      "weight": "SemiBold"
    },
    "caption": {
      "family": "Segoe UI Variable",
      "size": 12,
      "weight": "Normal"
    }
  },
  "palette": {
    "dark": {
      "foreground.primary": "#FFFFFF",
      "foreground.secondary": "#B3FFFFFF",
      "foreground.tertiary": "#8AFFFFFF",
      "foreground.disabled": "#55FFFFFF",
      "background.primary": "#80003062",
      "background.secondary": "Transparent",
      "background.tertiary": "#20FFFFFF",
      "accent": "#60CDFF",
      "accent.text": "#FFFFFF",
      "border.default": "#1AFFFFFF",
      "border.card": "#1AFFFFFF"
    },
    "light": {
      "foreground.primary": "#1B1B1B",
      "foreground.secondary": "#72000000",
      "foreground.tertiary": "#72000000",
      "foreground.disabled": "#551B1B1B",
      "background.primary": "#A0B0D4FF",
      "background.secondary": "#66C0DDFF",
      "background.tertiary": "#40FFFFFF",
      "accent": "#005FB8",
      "accent.text": "#FFFFFF",
      "border.default": "#20000000",
      "border.card": "#20000000"
    }
  },
  "backdrop": {
    "style": "Acrylic",
    "tintOpacity": 0.7,
    "luminosityOpacity": 0.75
  }
}
