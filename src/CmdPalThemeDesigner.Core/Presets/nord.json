{
  "version": 2,
  "name": "Nord",
  "author": "PowerToys",
  "description": "Inspired by the Arctic, north-bluish color palette",
  "fonts": {
    "primary": {
      "family": "Segoe UI",
      "size": 13,
      "weight": "Normal"
    },
    "monospace": {
      "family": "Cascadia Mono",
      "size": 12,
      "weight": "Normal"
    },
    "title": {
      "family": "Segoe UI",
      "size": 15,
      "weight": "Bold"
    },
    "caption": {
      "family": "Segoe UI",
      "size": 11,
      "weight": "Normal"
    }
  },
  "palette": {
    "dark": {
      "foreground.primary": "#ECEFF4",
      "foreground.secondary": "#D8DEE9",
      "foreground.tertiary": "#D8DEE9",
      "foreground.disabled": "#55ECEFF4",
      "background.primary": "#802E3440",
      "background.secondary": "Transparent",
      "background.tertiary": "#3B4252",
      "accent": "#88C0D0",
      "accent.text": "#FFFFFF",
      "border.default": "#434C5E",
      "border.card": "#434C5E"
    },
    "light": {
      "foreground.primary": "#2E3440",
      "foreground.secondary": "#4C566A",
      "foreground.tertiary": "#4C566A",
      "foreground.disabled": "#552E3440",
      "background.primary": "#A0ECEFF4",
      "background.secondary": "#66E5E9F0",
      "background.tertiary": "#ECEFF4",
      "accent": "#5E81AC",
      "accent.text": "#FFFFFF",
      "border.default": "#D8DEE9",
      "border.card": "#D8DEE9"
    }
  },
  "backdrop": {
    "style": "Acrylic",
    "tintOpacity": 0.88,
    "luminosityOpacity": 0.9
  }
}
