{
  "version": 2,
  "name": "Gruvbox Dark",
  "author": "PowerToys",
  "description": "Retro groove color scheme with warm earthy tones",
  "fonts": {
    "primary": {
      "family": "Trebuchet MS",
      "size": 14,
      "weight": "Normal"
    },
    "monospace": {
      "family": "Cascadia Code",
      "size": 14,
      "weight": "Normal"
    },
    "title": {
      "family": "Trebuchet MS",
      "size": 18,
      "weight": "Bold"
    },
    "caption": {
      "family": "Trebuchet MS",
      "size": 12,
      "weight": "Normal"
    }
  },
  "palette": {
    "dark": {
      "foreground.primary": "#EBDBB2",
      "foreground.secondary": "#A89984",
      "foreground.tertiary": "#A89984",
      "foreground.disabled": "#55EBDBB2",
      "background.primary": "#80282828",
      "background.secondary": "Transparent",
      "background.tertiary": "#3C3836",
      "accent": "#FE8019",
      "accent.text": "#FFFFFF",
      "border.default": "#504945",
      "border.card": "#504945"
    },
    "light": {
      "foreground.primary": "#3C3836",
      "foreground.secondary": "#665C54",
      "foreground.tertiary": "#665C54",
      "foreground.disabled": "#553C3836",
      "background.primary": "#A0FBF1C7",
      "background.secondary": "#66EBDBB2",
      "background.tertiary": "#EBDBB2",
      "accent": "#AF3A03",
      "accent.text": "#FFFFFF",
      "border.default": "#BDAE93",
      "border.card": "#D5C4A1"
    }
  },
  "backdrop": {
    "style": "Acrylic",
    "tintOpacity": 0.9,
    "luminosityOpacity": 0.85
  }
}
