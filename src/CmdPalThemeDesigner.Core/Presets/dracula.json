{
  "version": 2,
  "name": "Dracula",
  "author": "PowerToys",
  "description": "A dark theme inspired by the Dracula color scheme",
  "fonts": {
    "primary": {
      "family": "Cascadia Code",
      "size": 14,
      "weight": "Normal"
    },
    "monospace": {
      "family": "Cascadia Mono",
      "size": 13,
      "weight": "Normal"
    },
    "title": {
      "family": "Cascadia Code",
      "size": 16,
      "weight": "SemiBold"
    },
    "caption": {
      "family": "Cascadia Code",
      "size": 12,
      "weight": "Light"
    }
  },
  "palette": {
    "dark": {
      "foreground.primary": "#F8F8F2",
      "foreground.secondary": "#6272A4",
      "foreground.tertiary": "#6272A4",
      "foreground.disabled": "#55F8F8F2",
      "background.primary": "#80282A36",
      "background.secondary": "Transparent",
      "background.tertiary": "#44475A",
      "accent": "#BD93F9",
      "accent.text": "#FFFFFF",
      "border.default": "#6272A4",
      "border.card": "#6272A4"
    },
    "light": {
      "foreground.primary": "#282A36",
      "foreground.secondary": "#6272A4",
      "foreground.tertiary": "#6272A4",
      "foreground.disabled": "#55282A36",
      "background.primary": "#A0F8F8F2",
      "background.secondary": "#66F8F8F2",
      "background.tertiary": "#FFFFFF",
      "accent": "#7C3AED",
      "accent.text": "#FFFFFF",
      "border.default": "#D6D6D6",
      "border.card": "#D6D6D6"
    }
  },
  "backdrop": {
    "style": "Acrylic",
    "tintOpacity": 0.9,
    "luminosityOpacity": 0.85
  }
}
