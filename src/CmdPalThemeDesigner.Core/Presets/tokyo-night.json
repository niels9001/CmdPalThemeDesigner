{
  "version": 2,
  "name": "Tokyo Night",
  "author": "PowerToys",
  "description": "A clean dark theme inspired by Tokyo city lights",
  "fonts": {
    "primary": {
      "family": "Consolas",
      "size": 14,
      "weight": "Normal"
    },
    "monospace": {
      "family": "Consolas",
      "size": 13,
      "weight": "Normal"
    },
    "title": {
      "family": "Consolas",
      "size": 16,
      "weight": "Bold"
    },
    "caption": {
      "family": "Consolas",
      "size": 11,
      "weight": "Normal"
    }
  },
  "palette": {
    "dark": {
      "foreground.primary": "#C0CAF5",
      "foreground.secondary": "#565F89",
      "foreground.tertiary": "#565F89",
      "foreground.disabled": "#55C0CAF5",
      "background.primary": "#801A1B26",
      "background.secondary": "Transparent",
      "background.tertiary": "#24283B",
      "accent": "#7AA2F7",
      "accent.text": "#FFFFFF",
      "border.default": "#3B4261",
      "border.card": "#3B4261"
    },
    "light": {
      "foreground.primary": "#343B59",
      "foreground.secondary": "#6172AF",
      "foreground.tertiary": "#6172AF",
      "foreground.disabled": "#55343B59",
      "background.primary": "#A0D5D6DB",
      "background.secondary": "#66E1E2E7",
      "background.tertiary": "#E1E2E7",
      "accent": "#2E7DE9",
      "accent.text": "#FFFFFF",
      "border.default": "#9699A3",
      "border.card": "#C0C1CC"
    }
  },
  "backdrop": {
    "style": "Acrylic",
    "tintOpacity": 0.9,
    "luminosityOpacity": 0.85
  }
}
