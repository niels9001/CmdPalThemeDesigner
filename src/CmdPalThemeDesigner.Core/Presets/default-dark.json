{
  "version": 2,
  "name": "Default Dark",
  "author": "PowerToys",
  "description": "The default dark theme matching CmdPal's standard appearance",
  "fonts": {
    "primary": {
      "family": "Segoe UI Variable",
      "size": 14,
      "weight": "Normal"
    },
    "monospace": {
      "family": "Cascadia Code",
      "size": 13,
      "weight": "Normal"
    },
    "title": {
      "family": "Segoe UI Variable",
      "size": 16,
      "weight": "SemiBold"
    },
    "caption": {
      "family": "Segoe UI Variable",
      "size": 12,
      "weight": "Normal"
    }
  },
  "palette": {
    "dark": {
      "foreground.primary": "#FFFFFF",
      "foreground.secondary": "#8AFFFFFF",
      "foreground.tertiary": "#8AFFFFFF",
      "foreground.disabled": "#55FFFFFF",
      "background.primary": "#50202020",
      "background.secondary": "Transparent",
      "background.tertiary": "#0DFFFFFF",
      "accent": "#60CDFF",
      "accent.text": "#FFFFFF",
      "border.default": "#14FFFFFF",
      "border.card": "#14FFFFFF"
    },
    "light": {
      "foreground.primary": "#1B1B1B",
      "foreground.secondary": "#72000000",
      "foreground.tertiary": "#72000000",
      "foreground.disabled": "#551B1B1B",
      "background.primary": "#A0FFFFFF",
      "background.secondary": "#66FFFFFF",
      "background.tertiary": "#06000000",
      "accent": "#005FB8",
      "accent.text": "#FFFFFF",
      "border.default": "#0A000000",
      "border.card": "#0F000000"
    }
  },
  "backdrop": {
    "style": "Acrylic",
    "tintOpacity": 0.85,
    "luminosityOpacity": 0.9
  }
}
