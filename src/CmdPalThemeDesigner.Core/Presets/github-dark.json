{
  "version": 2,
  "name": "GitHub Dark",
  "author": "PowerToys",
  "description": "GitHub's official dark theme colors",
  "fonts": {
    "primary": {
      "family": "Segoe UI Variable",
      "size": 14,
      "weight": "Medium"
    },
    "monospace": {
      "family": "Cascadia Mono",
      "size": 13,
      "weight": "Normal"
    },
    "title": {
      "family": "Segoe UI Variable",
      "size": 16,
      "weight": "Bold"
    },
    "caption": {
      "family": "Segoe UI Variable",
      "size": 12,
      "weight": "Light"
    }
  },
  "palette": {
    "dark": {
      "foreground.primary": "#C9D1D9",
      "foreground.secondary": "#8B949E",
      "foreground.tertiary": "#8B949E",
      "foreground.disabled": "#55C9D1D9",
      "background.primary": "#800D1117",
      "background.secondary": "Transparent",
      "background.tertiary": "#161B22",
      "accent": "#58A6FF",
      "accent.text": "#FFFFFF",
      "border.default": "#30363D",
      "border.card": "#30363D"
    },
    "light": {
      "foreground.primary": "#24292F",
      "foreground.secondary": "#57606A",
      "foreground.tertiary": "#57606A",
      "foreground.disabled": "#5524292F",
      "background.primary": "#A0FFFFFF",
      "background.secondary": "#66F6F8FA",
      "background.tertiary": "#F6F8FA",
      "accent": "#0969DA",
      "accent.text": "#FFFFFF",
      "border.default": "#D8DEE4",
      "border.card": "#D0D7DE"
    }
  },
  "backdrop": {
    "style": "Acrylic",
    "tintOpacity": 0.9,
    "luminosityOpacity": 0.85
  }
}
