{
  "version": 2,
  "name": "One Dark",
  "author": "PowerToys",
  "description": "Atom's iconic dark theme adapted for CmdPal",
  "fonts": {
    "primary": {
      "family": "Verdana",
      "size": 13,
      "weight": "Normal"
    },
    "monospace": {
      "family": "Consolas",
      "size": 13,
      "weight": "Normal"
    },
    "title": {
      "family": "Verdana",
      "size": 15,
      "weight": "Bold"
    },
    "caption": {
      "family": "Verdana",
      "size": 11,
      "weight": "Normal"
    }
  },
  "palette": {
    "dark": {
      "foreground.primary": "#ABB2BF",
      "foreground.secondary": "#5C6370",
      "foreground.tertiary": "#5C6370",
      "foreground.disabled": "#55ABB2BF",
      "background.primary": "#80282C34",
      "background.secondary": "Transparent",
      "background.tertiary": "#21252B",
      "accent": "#61AFEF",
      "accent.text": "#FFFFFF",
      "border.default": "#3E4451",
      "border.card": "#3E4451"
    },
    "light": {
      "foreground.primary": "#383A42",
      "foreground.secondary": "#A0A1A7",
      "foreground.tertiary": "#A0A1A7",
      "foreground.disabled": "#55383A42",
      "background.primary": "#A0FAFAFA",
      "background.secondary": "#66F0F0F0",
      "background.tertiary": "#F0F0F0",
      "accent": "#4078F2",
      "accent.text": "#FFFFFF",
      "border.default": "#A0A1A7",
      "border.card": "#DBDBDC"
    }
  },
  "backdrop": {
    "style": "Acrylic",
    "tintOpacity": 0.9,
    "luminosityOpacity": 0.85
  }
}
